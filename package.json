{
  "name": "@drivardxrm/pptb-customapi-studio",
  "version": "0.0.1",
  "displayName": "Custom API Studio",
  "description": "All‑in‑one workspace for creating, managing, and extending Dataverse Custom APIs and Business events (Catalogs)",
  "main": "index.html",
  "author": "David Rivard",
  "license": "MIT",
  "keywords": [
    "powerplatform",
    "power-apps",
    "dataverse",
    "customapi",
    "business-event",
    "catalog",
    "crm",
    "xrm",
    "microsoft"
  ],
  "cspExceptions": {
    "connect-src": [
      "https://*.dynamics.com",
      "https://*.crm*.dynamics.com"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/drivardxrm/PPTB-Dataverse-Custom-API-Manager"
  },
  "bugs": {
    "url": "https://github.com/drivardxrm/PPTB-Dataverse-Custom-API-Manager/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:watch": "tsc && vite build --watch",
    "dev": "vite",
    "dev:test": "vite --mode test",
    "preview": "vite preview",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=tests/e2e/playwright.config.ts --ui",
    "test:e2e:report": "npx playwright show-report"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.73.1",
    "@fluentui/react-datepicker-compat": "^0.6.23",
    "@monaco-editor/react": "^4.8.0-rc.3",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@uiw/react-json-view": "^2.0.0-alpha.41",
    "immer": "^11.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-query-key-manager": "^0.0.113",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@pptb/types": "1.2.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "files": [
    "dist"
  ]
}
