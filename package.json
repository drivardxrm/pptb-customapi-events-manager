{
  "name": "@drivardxrm/pptb-customapi-events-manager",
  "version": "1.0.0",
  "displayName": "Custom API & Events Manager",
  "description": "All‑in‑one workspace for creating, managing, and testing Dataverse Custom APIs and Business events (Catalogs)",
  "main": "index.html",
  "author": "David Rivard",
  "license": "MIT",
  "icon": "public/icons/logo.svg",
  "contributors": [
    {
      "name": "David Rivard",
      "url": "https://github.com/drivardxrm"
    }
  ],
  "configurations": {
    "repository": "https://github.com/drivardxrm/pptb-customapi-events-manager",
    "website": "https://drivardxrm.github.io/pptb-customapi-events-manager/",
    "readmeUrl": "https://raw.githubusercontent.com/drivardxrm/pptb-customapi-events-manager/main/README.md"
  },
  "keywords": [
    "powerplatform",
    "power-apps",
    "dataverse",
    "customapi",
    "business-event",
    "catalog",
    "crm",
    "xrm",
    "microsoft"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/drivardxrm/pptb-customapi-events-manager"
  },
  "bugs": {
    "url": "https://github.com/drivardxrm/pptb-customapi-events-manager/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@11.10.0",
  "scripts": {
    "build": "tsc && vite build",
    "build:watch": "tsc && vite build --watch",
    "dev": "vite",
    "dev:test": "vite --mode test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "preview": "vite preview",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=tests/e2e/playwright.config.ts --ui",
    "test:e2e:report": "npx playwright show-report",
    "validate": "pptb-validate"
  },
  "dependencies": {
    "@fluentui/react-components": "9.73.8",
    "@fluentui/react-datepicker-compat": "^0.6.32",
    "@fluentui/react-icons": "^2.0.328",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@uiw/react-json-view": "^2.0.0-alpha.43",
    "immer": "^11.1.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-query-key-manager": "^0.0.2",
    "uuid": "^13.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@pptb/types": "^1.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.7",
    "vitepress": "^2.0.0-alpha.17"
  },
  "files": [
    "dist"
  ]
}
